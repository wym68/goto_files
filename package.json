{
  "name": "goto-files",
  "displayName": "Goto Files",
  "description": "Ctrl+Click to open file paths in shell scripts",
  "version": "0.0.1",
  "publisher": "wym68",
  "repository": "https://github.com/wym68/goto_files",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "shell",
    "sh",
    "file path",
    "goto",
    "navigation"
  ],
  "activationEvents": [
    "onLanguage:shellscript"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
